# ========== CRITICAL: MUST SET IN PRODUCTION ==========
NODE_ENV=production
PORT=3001
DATABASE_URL="mysql://user:password@host:3306/startech"
JWT_SECRET="your-super-strong-jwt-secret-here-min-32-chars"
CORS_ORIGINS="https://yourdomain.com,http://localhost:3000"

# ========== REQUIRED FOR EMAIL FEATURES ==========
SMTP_HOST=mail.yourdomain.com
SMTP_PORT=465
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=your-smtp-password
SMTP_SECURE=true
FROM_NAME=YourCompanyName
FROM_EMAIL=noreply@yourdomain.com

# ========== OPTIONAL: Google Integration ==========
GOOGLE_SHEET_ID=your-google-sheet-id
GOOGLE_SERVICE_ACCOUNT_KEY_BASE64="your-base64-encoded-key-here"

# ========== OPTIONAL: SEED CONFIGURATION ==========
# NEVER set to true in production unless explicitly importing data
ALLOW_DESTRUCTIVE_SEED="false"

# ========== OPTIONAL: LOGGING ==========
LOG_LEVEL="warn"
# Options: error, warn, info, debug, verbose, silly

# ========== NOTES FOR PRODUCTION DEPLOYMENT ==========
# 1. NODE_ENV MUST be "production" to enable security checks
# 2. JWT_SECRET must be different from development, at least 32 chars
# 3. Database password must be strong and rotated regularly
# 4. CORS_ORIGINS must list your exact domain(s), no wildcards
# 5. SMTP credentials should use app-specific passwords, not main account
# 6. ALLOW_DESTRUCTIVE_SEED must be "false" for production databases
# 7. Never commit actual secrets to git - use environment variables
# 8. Verify all env vars are set before starting production server
