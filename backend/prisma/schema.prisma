// ================================
// DATABASE: Website Design Services
// ================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ========== Model: Danh mục sản phẩm ==========
model Category {
  id               Int                @id @default(autoincrement())
  name             String             @db.VarChar(191)
  product_category ProductCategory[]

  @@index([id])
  @@map("category")
}

// ========== Model: Dịch vụ ==========
model Service {
  id              Int               @id @default(autoincrement())
  name            String            @db.VarChar(191)
  product_service ProductService[]

  @@map("services")
}

// ========== Model: Sản phẩm ==========
model Product {
  id               Int                @id @default(autoincrement())
  slug             String?            @unique(map: "product_slug_unique") @db.VarChar(191)
  name             String             @db.VarChar(191)
  price            Decimal?           @db.Decimal(10, 2)
  price_Type       PriceType
  rating           Decimal            @default(0.0) @db.Decimal(2, 1)
  like             Int?               @default(0)
  completion_time  String?            @db.VarChar(100)
  description      String             @db.Text
  image_url        String             @db.VarChar(255)
  demo_url         String?            @db.VarChar(255)
  createdAt       DateTime           @default(now()) @db.DateTime(0)
  updatedAt       DateTime           @updatedAt @db.DateTime(0)

  product_category ProductCategory[]
  product_service  ProductService[]
  images           ProductImage[]

  @@index([name], map: "product_name_idx")
  @@index([slug], map: "product_slug_idx")
  @@fulltext([name, description], map: "product_fulltext_idx")
  @@map("product")
}

// ========== Model: Bảng trung gian Product - Category ==========
model ProductCategory {
  id          Int         @id @default(autoincrement())
  product_id  Int
  category_id Int

  product  Product     @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  category Category  @relation(fields: [category_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([product_id, category_id], map: "unique_product_category")
  @@index([product_id], map: "product_category_product_idx")
  @@index([category_id], map: "product_category_category_idx")
  @@map("product_cat")
}

// ========== Model: Ảnh phụ ==========
model ProductImage {
  id         Int     @id @default(autoincrement())
  product_id Int
  url        String  @db.VarChar(255)

  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([product_id], map: "images_product_idx")
  @@map("images")
}

// ========== Model: Bảng trung gian Product - Service ==========
model ProductService {
  id         Int      @id @default(autoincrement())
  product_id Int
  service_id Int

  product Product  @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  service Service @relation(fields: [service_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([product_id], map: "product_service_product_idx")
  @@index([service_id], map: "product_service_service_idx")
  @@map("product_service")
}

// ========== Model: Phản hồi khách hàng ==========
model Feedback {
  id         Int      @id @default(autoincrement())
  name       String   @db.VarChar(191)
  comment    String   @db.Text
  rating     Decimal  @db.Decimal(2, 1)
  createdAt DateTime @default(now()) @db.DateTime(0)

  @@map("feedback")
}

// ========== Model: Tính năng ==========
model Feature {
  id              Int               @id @default(autoincrement())
  name            String            @db.VarChar(191)
  description     String?           @db.Text
  pricing_feature PricingFeature[]

  @@map("feature")
}

// ========== Model: Gói dịch vụ ==========
model PricingPlan {
  id              Int               @id @default(autoincrement())
  name            String            @db.VarChar(191)
  price           Decimal?          @db.Decimal(10, 2) 
  price_Type      PriceType
  description     String?           @db.Text
  pricing_feature PricingFeature[]

  @@map("pricing_plan")
}

// ========== Model: Bảng trung gian Pricing - Feature ==========
model PricingFeature {
  id              Int          @id @default(autoincrement())
  pricing_plan_id Int
  feature_id      Int

  pricing_plan PricingPlan @relation(fields: [pricing_plan_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  feature      Feature      @relation(fields: [feature_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([pricing_plan_id], map: "pricing_feature_plan_idx")
  @@index([feature_id], map: "pricing_feature_feature_idx")
  @@map("pricing_feature")
}

model ShowcaseItem {
  id            Int      @id @default(autoincrement())
  image_url     String   @db.VarChar(255)
  name          String   @db.VarChar(255)
  description   String   @db.Text
  website_url   String?  @db.VarChar(255)
  display_order Int      @default(0)
  createdAt     DateTime @default(now()) @db.DateTime(0)
  updatedAt     DateTime @updatedAt @db.DateTime(0)

  @@index([display_order], map: "showcase_item_display_order_idx")
  @@map("showcase_item")
}

model ContactSubmission {
  id         Int                     @id @default(autoincrement())
  name       String                  @db.VarChar(191)
  email      String                  @db.VarChar(191)
  phone      String                  @db.VarChar(20)
  company    String?                 @db.VarChar(191)
  service    String?                 @db.VarChar(191)
  message    String                  @db.Text
  status     ContactSubmissionStatus @default(WAITING)
  createdAt  DateTime                @default(now()) @db.DateTime(0)
  updatedAt  DateTime                @updatedAt @db.DateTime(0)

  @@index([email], map: "contact_submission_email_idx")
  @@index([status], map: "contact_submission_status_idx")
  @@map("contact_submission")
}

enum PriceType {
  FIXED
  CONTACT
}

enum ContactSubmissionStatus {
  WAITING
  VIEWED
  PROCESSED
}

enum UserRole {
  SUPER_ADMIN
  EDITOR
  VIEWER
}

enum ContentWorkflowStatus {
  DRAFT
  IN_REVIEW
  CHANGES_REQUESTED
  APPROVED
  PUBLISHED
}

model SitePage {
  id              Int           @id @default(autoincrement())
  slug            String        @unique @db.VarChar(191)
  title           String        @db.VarChar(191)
  seoTitle        String?       @map("seo_title") @db.VarChar(191)
  seoDescription  String?       @map("seo_description") @db.Text
  heroBadge       String?       @map("hero_badge") @db.VarChar(191)
  heroTitle       String?       @map("hero_title") @db.VarChar(255)
  heroDescription String?       @map("hero_description") @db.Text
  workflowStatus  ContentWorkflowStatus @default(DRAFT) @map("workflow_status")
  publishedVersionId Int?       @unique @map("published_version_id")
  submittedAt     DateTime?     @map("submitted_at") @db.DateTime(0)
  approvedAt      DateTime?     @map("approved_at") @db.DateTime(0)
  publishedAt     DateTime?     @map("published_at") @db.DateTime(0)
  createdBy       String?       @map("created_by") @db.VarChar(191)
  updatedBy       String?       @map("updated_by") @db.VarChar(191)
  deletedAt       DateTime?     @map("deleted_at") @db.DateTime(0)
  createdAt       DateTime      @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.DateTime(0)
  sections        PageSection[]
  faqs            FaqItem[]
  versions        SitePageVersion[]
  publishedVersion SitePageVersion? @relation("PublishedSitePageVersion", fields: [publishedVersionId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([slug], map: "site_page_slug_idx")
  @@index([workflowStatus], map: "site_page_workflow_status_idx")
  @@map("site_page")
}

model PageSection {
  id                   Int       @id @default(autoincrement())
  pageId               Int       @map("page_id")
  sectionKey           String    @map("section_key") @db.VarChar(100)
  title                String?   @db.VarChar(191)
  subtitle             String?   @db.VarChar(191)
  description          String?   @db.Text
  imageUrl             String?   @map("image_url") @db.VarChar(255)
  primaryButtonLabel   String?   @map("primary_button_label") @db.VarChar(100)
  primaryButtonHref    String?   @map("primary_button_href") @db.VarChar(255)
  secondaryButtonLabel String?   @map("secondary_button_label") @db.VarChar(100)
  secondaryButtonHref  String?   @map("secondary_button_href") @db.VarChar(255)
  contentJson          Json?     @map("content_json")
  displayOrder         Int       @default(0) @map("display_order")
  isActive             Boolean   @default(true) @map("is_active")
  createdBy            String?   @map("created_by") @db.VarChar(191)
  updatedBy            String?   @map("updated_by") @db.VarChar(191)
  deletedAt            DateTime? @map("deleted_at") @db.DateTime(0)
  createdAt            DateTime  @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt            DateTime  @updatedAt @map("updated_at") @db.DateTime(0)

  page SitePage @relation(fields: [pageId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([pageId], map: "page_section_page_id_idx")
  @@index([sectionKey], map: "page_section_key_idx")
  @@map("page_section")
}

model FaqItem {
  id           Int       @id @default(autoincrement())
  pageId       Int       @map("page_id")
  question     String    @db.VarChar(255)
  answer       String    @db.Text
  displayOrder Int       @default(0) @map("display_order")
  isActive     Boolean   @default(true) @map("is_active")
  createdBy    String?   @map("created_by") @db.VarChar(191)
  updatedBy    String?   @map("updated_by") @db.VarChar(191)
  deletedAt    DateTime? @map("deleted_at") @db.DateTime(0)
  createdAt    DateTime  @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.DateTime(0)

  page SitePage @relation(fields: [pageId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([pageId], map: "faq_item_page_id_idx")
  @@index([displayOrder], map: "faq_item_display_order_idx")
  @@map("faq_item")
}

model SiteSetting {
  id         Int       @id @default(autoincrement())
  settingKey String    @unique @map("setting_key") @db.VarChar(191)
  settingVal String    @map("setting_val") @db.Text
  type       String    @default("string") @db.VarChar(50)
  createdBy  String?   @map("created_by") @db.VarChar(191)
  updatedBy  String?   @map("updated_by") @db.VarChar(191)
  deletedAt  DateTime? @map("deleted_at") @db.DateTime(0)
  createdAt  DateTime  @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.DateTime(0)

  @@map("site_setting")
}

model User {
  id           Int       @id @default(autoincrement())
  email        String    @unique @db.VarChar(191)
  fullName     String    @map("full_name") @db.VarChar(191)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  role         UserRole  @default(EDITOR)
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at") @db.DateTime(0)
  createdAt    DateTime  @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.DateTime(0)
  refreshTokens RefreshToken[]

  @@index([role], map: "user_role_idx")
  @@index([isActive], map: "user_is_active_idx")
  @@map("user")
}

model RefreshToken {
  id           Int       @id @default(autoincrement())
  userId       Int       @map("user_id")
  tokenHash    String    @map("token_hash") @db.VarChar(255)
  expiresAt    DateTime  @map("expires_at") @db.DateTime(0)
  revokedAt    DateTime? @map("revoked_at") @db.DateTime(0)
  createdAt    DateTime  @default(now()) @map("created_at") @db.DateTime(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId], map: "refresh_token_user_id_idx")
  @@index([expiresAt], map: "refresh_token_expires_at_idx")
  @@map("refresh_token")
}

model MediaAsset {
  id           Int      @id @default(autoincrement())
  fileName     String   @map("file_name") @db.VarChar(255)
  originalName String   @map("original_name") @db.VarChar(255)
  mimeType     String   @map("mime_type") @db.VarChar(100)
  size         Int
  storagePath  String   @map("storage_path") @db.VarChar(255)
  publicUrl    String   @map("public_url") @db.VarChar(255)
  createdAt    DateTime @default(now()) @map("created_at") @db.DateTime(0)

  @@index([mimeType], map: "media_asset_mime_type_idx")
  @@map("media_asset")
}

model SitePageVersion {
  id            Int                   @id @default(autoincrement())
  pageId         Int                   @map("page_id")
  versionNumber  Int                   @map("version_number")
  workflowStatus ContentWorkflowStatus @map("workflow_status")
  snapshotJson   Json                  @map("snapshot_json")
  notes          String?               @db.Text
  approvedBy     String?               @map("approved_by") @db.VarChar(191)
  publishedBy    String?               @map("published_by") @db.VarChar(191)
  createdAt      DateTime              @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt      DateTime              @updatedAt @map("updated_at") @db.DateTime(0)

  page             SitePage  @relation(fields: [pageId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  publishedForPage SitePage? @relation("PublishedSitePageVersion")

  @@unique([pageId, versionNumber], map: "site_page_version_page_version_unique")
  @@index([pageId], map: "site_page_version_page_idx")
  @@index([workflowStatus], map: "site_page_version_status_idx")
  @@map("site_page_version")
}

model ContentAuditLog {
  id         Int      @id @default(autoincrement())
  entityType String   @map("entity_type") @db.VarChar(100)
  entityId   String?  @map("entity_id") @db.VarChar(191)
  action     String   @db.VarChar(100)
  actorId    String?  @map("actor_id") @db.VarChar(191)
  metadata   Json?    @map("metadata")
  createdAt  DateTime @default(now()) @map("created_at") @db.DateTime(0)

  @@index([entityType, entityId], map: "content_audit_entity_idx")
  @@index([action], map: "content_audit_action_idx")
  @@map("content_audit_log")
}

